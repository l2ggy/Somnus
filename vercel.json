{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "web/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/web/index.html"
    },
    {
      "src": "^/styles/(.*)$",
      "dest": "/web/styles/$1"
    },
    {
      "src": "^/assets/(.*)$",
      "dest": "/web/assets/$1"
    },
    {
      "src": "^/web/(.*)$",
      "dest": "/web/$1"
    }
  ]
}
