{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/session/start",
      "methods": ["POST", "OPTIONS"],
      "dest": "https://somnus-api.onrender.com/session/start"
    }
  ]
}
